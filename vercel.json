{
  "version": 2,
  "name": "001-sprint-01-week-01-uber-app",
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/swagger-ui\\.(.*)",
      "dest": "/api/swagger-ui.$1"
    },
    {
      "src": "/api/swagger-ui-init\\.js",
      "dest": "/api/swagger-ui-init.js"
    },
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ]
}
