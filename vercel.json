{
  "version": 2,
  "name": "001-sprint-01-week-01-uber-app",
  "builds": [{ "src": "src/index.ts", "use": "@vercel/node" }],
  "routes": [
    { "src": "/swagger-ui/(.*)", "dest": "/public/swagger-ui/$1" },
    { "src": "/swagger.json", "dest": "src/index.ts" },
    { "src": "/(.*)", "dest": "src/index.ts" }
  ]
}
